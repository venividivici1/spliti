# HTTP Basic Auth password for the UI and API (any username works).
BASIC_AUTH_PASSWORD=change-me

# Mistral API key — powers the optional "ask" chat and expense-description
# suggestions. Leave empty to run Spliti without any AI features.
MISTRAL_API_KEY=

# Cloud Firestore mirror (optional). SQLite stays the source of truth; setting a
# project id turns on a best-effort background mirror of every write to
# Firestore. Leave empty to run on SQLite alone. Requires the extra deps:
# `pip install -e ".[firestore]"`.
FIRESTORE_PROJECT_ID=
# Path to a service-account JSON key. If empty, Application Default Credentials
# are used (GOOGLE_APPLICATION_CREDENTIALS, gcloud login, or GCE/Cloud Run metadata).
FIRESTORE_CREDENTIALS=
